{
    "manifest-version": 3,
    "name": "capell-app/example",
    "slug": "example",
    "displayName": "Example",
    "kind": "package",
    "capellApiVersion": "^0.0",
    "version": "0.0.x-dev",
    "product": {
        "group": "Developer Tools",
        "tier": "premium",
        "bundle": "platform"
    },
    "surfaces": ["admin"],
    "dependencies": {
        "requires": ["capell-app/core"],
        "supports": [],
