<?php

declare(strict_types=1);

use {{ namespace }}\Actions\BuildPublicRenderStateAction;

it('renders public hook output without authoring details', function (): void {
    $html = view('{{ slug }}::hooks.public-example', [
        'state' => BuildPublicRenderStateAction::run(),
    ])->render();

    expect($html)
        ->toContain('safe public package output')
        ->not->toContain('filament')
        ->not->toContain('admin')
        ->not->toContain('editor')
        ->not->toContain('signed')
        ->not->toContain('wire:')
        ->not->toContain('data-field')
        ->not->toContain('{{ packageName }}');
});
